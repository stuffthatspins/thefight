# Supabase (required)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (for admin send – never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=newsletter@yourdomain.com
SENDGRID_FROM_NAME=The Fight

# Admin (use base64 if password has $ or other special chars)
# To encode: echo -n 'your-password' | base64
ADMIN_PASSWORD_B64=
